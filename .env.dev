# VeritasAd Environment Variables для Development (Docker)
# Используется с docker-compose.dev.yml

# ==================== POSTGRESQL ====================
POSTGRES_PASSWORD=veritasad123

# ==================== TELEGRAM BOT ====================
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ==================== BOT ADMIN (опционально) ====================
BOT_ADMIN_IDS=

# ==================== SENTRY (опционально) ====================
SENTRY_DSN=

# ==================== DEVELOPMENT / TESTING ====================
# Отключить авторизацию для тестирования функционала
DISABLE_AUTH=true
NEXT_PUBLIC_DISABLE_AUTH=true

# ==================== LOGGING ====================
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# ==================== BRAND DETECTION ====================
BRANDS_FILE=
DEFAULT_BRANDS=
ENABLE_BRAND_OCR=true
ENABLE_ZERO_SHOT=true
BRAND_DETECTION_THRESHOLD=0.12
BRAND_MAX_FRAMES=50
BRAND_FRAME_INTERVAL=1.0
