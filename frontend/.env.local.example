# VeritasAd Frontend Environment Variables

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Self-hosted MVP mode without Supabase.
# Set to true if you want to connect the frontend to your own backend first.
NEXT_PUBLIC_DISABLE_AUTH=false

# Supabase Configuration
# Use these when you want the full hosted auth flow instead of mock/self-hosted mode.
NEXT_PUBLIC_SUPABASE_URL=https://zpfktkvgurpsyyecdibf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ==================== TELEGRAM INTEGRATION ====================
# Telegram Bot Username (without @)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=veritasadbot
