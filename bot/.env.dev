# Telegram Bot Configuration для Development (Docker)

# Required: Get token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Backend API URL
API_URL=http://backend:8000

# Redis for FSM
REDIS_URL=redis://redis:6379/2

# Environment
ENVIRONMENT=development

# Bot admin user IDs (comma-separated, optional)
BOT_ADMIN_IDS=

# Bot username (without @) - for deep linking
BOT_USERNAME=VeritasAdBot
