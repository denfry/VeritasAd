# VeritasAD Bot Configuration — Railway Production

# Required: Get token from @BotFather
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>

# Backend API URL — use Railway internal URL for backend service
API_URL=<railway-backend-internal-url>

# Redis for FSM — Railway provides REDIS_URL
REDIS_URL=<from Railway Redis reference>/2

# Environment
ENVIRONMENT=production

# Bot admin user IDs (comma-separated, optional)
BOT_ADMIN_IDS=

# Webhook (optional, for production)
WEBHOOK_URL=
WEBHOOK_SECRET=

# Bot username (without @)
BOT_USERNAME=veritasadbot

# Secret key for bot-to-backend authentication (must match backend BOT_SECRET_KEY)
BOT_SECRET_KEY=<same-as-backend-bot-secret-key>
