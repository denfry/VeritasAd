# syntax=docker/dockerfile:1
# Development Dockerfile с hot reload и кэшированием

FROM python:3.12-slim

# Устанавливаем зависимости для разработки
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    curl \
    ffmpeg \
    tesseract-ocr \
    tesseract-ocr-rus \
    nodejs \
    npm \
    aria2 \
    yt-dlp \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Копируем только файлы зависимостей для кэширования
COPY pyproject.toml uv.lock README.md ./

# Кэшируем установку зависимостей через uv
RUN uv sync --frozen --no-dev

# Place the venv on the PATH
ENV PATH="/app/.venv/bin:$PATH"

# Копируем остальной код (исключая .dockerignore)
COPY . .

# Создаём директорию для данных
RUN mkdir -p /app/data /app/models

# Expose port
EXPOSE 8000

# Скрипт запуска с выполнением миграций
COPY <<EOF /app/entrypoint.sh
#!/bin/bash
set -e

# Выполняем миграции Alembic перед запуском, если не задана переменная SKIP_MIGRATIONS
if [ "\$SKIP_MIGRATIONS" != "true" ]; then
    echo "Running Alembic migrations..."
    # Пытаемся запустить миграции с небольшой задержкой/повторами в случае конфликтов таблиц версий
    for i in {1..5}; do
        alembic upgrade head && break || {
            echo "Migration attempt \$i failed, retrying in 2s..."
            sleep 2
        }
    done
else
    echo "Skipping migrations as requested..."
fi

# Запускаем основную команду
exec "\$@"
EOF

RUN chmod +x /app/entrypoint.sh

ENTRYPOINT ["/app/entrypoint.sh"]

# Запуск с hot reload через uvicorn
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
