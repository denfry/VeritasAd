# VeritasAD Backend Configuration — Railway Production
# Copy this file and fill in your values for Railway deployment

# ==================== PROJECT SETTINGS ====================
PROJECT_NAME=VeritasAD
API_V1_STR=/api/v1
VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production

# ==================== DATABASE ====================
# Railway provides DATABASE_URL automatically
# DATABASE_URL=<from Railway PostgreSQL reference>

# ==================== REDIS ====================
# Railway provides REDIS_URL automatically
# REDIS_URL=<from Railway Redis reference>

# ==================== CELERY ====================
CELERY_BROKER_URL=<from Railway Redis reference>
CELERY_RESULT_BACKEND=<from Railway Redis reference>/1

# ==================== SECURITY ====================
SECRET_KEY=<generate: python -c "import secrets; print(secrets.token_urlsafe(64))">
JWT_SECRET_KEY=<generate: python -c "import secrets; print(secrets.token_urlsafe(64))">
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DISABLE_AUTH=false

# CORS — update with your Railway frontend URL
CORS_ORIGINS=["https://your-frontend.up.railway.app"]
TRUSTED_HOSTS=["*.up.railway.app"]

# ==================== SUPABASE AUTH ====================
SUPABASE_URL=https://zpfktkvgurpsyyecdibf.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key-from-dashboard>
SUPABASE_JWT_SECRET=<your-supabase-jwt-secret-from-dashboard>

# ==================== TELEGRAM BOT ====================
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token-from-botfather>
BOT_SECRET_KEY=<generate-a-random-secret-for-bot-auth>

# ==================== FILE PROCESSING ====================
MAX_VIDEO_DURATION=600
MAX_FILE_SIZE=2147483648
DOWNLOAD_CONCURRENT_FRAGMENTS=8
USE_ARIA2C=true

# ==================== ML MODELS ====================
USE_LLM=False
WHISPER_MODEL=tiny
CLIP_MODEL=openai/clip-vit-base-patch32
TORCH_DEVICE=cpu

# ==================== PATHS ====================
DATA_DIR=/app/data
MODELS_DIR=/app/models
REPORTS_DIR=/app/data/reports
TEMP_DIR=/app/data/temp
UPLOAD_DIR=/app/data/uploads

# ==================== MONITORING ====================
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_METRICS=True
ENABLE_TRACING=False

# ==================== PAYMENT ====================
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://your-frontend.up.railway.app/payment/success
